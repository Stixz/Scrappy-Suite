# 🜂 **SCRAPPY MODULE #2 — TASKS**  
*(Copy/paste ready, matches the Notes module structure)*

```
const tasks = {
  id: "tasks",
  name: "Tasks",
  icon: "🧷",
  color: "#8fbf88",

  state: {
    selected: null,
    filter: "",
    items: []
  },

  actions: {
    create(data) {
      const id = "task-" + Date.now().toString(36)
      scrappy.db.tasks.push({
        id,
        title: data.title || "Untitled Task",
        done: false,
        noteLink: data.noteLink || null,   // optional link to a note
        created: Date.now()
      })

      scrappy.emit("tasks:created", { id })
      return id
    },

    open(id) {
      tasks.state.selected = id
      scrappy.emit("tasks:opened", { id })
    },

    save(id, data) {
      const item = scrappy.db.tasks.find(t => t.id === id)
      Object.assign(item, data)
      scrappy.emit("tasks:saved", { id })
    },

    remove(id) {
      scrappy.db.tasks = scrappy.db.tasks.filter(t => t.id !== id)
      scrappy.emit("tasks:removed", { id })
    },

    toggle(id) {
      const item = scrappy.db.tasks.find(t => t.id === id)
      item.done = !item.done
      scrappy.emit("tasks:toggled", { id, done: item.done })
    }
  },

  renderMain(container) {
    container.innerHTML = `
      <h1>Tasks</h1>
      <button id="newTaskBtn">New Task</button>
      <ul id="taskList"></ul>
    `

    const list = container.querySelector("#taskList")

    list.innerHTML = scrappy.db.tasks
      .map(t => `
        <li data-id="${t.id}">
          <input type="checkbox" ${t.done ? "checked" : ""}>
          <span>${t.title}</span>
          ${t.noteLink ? `<a href="${t.noteLink}">🗒️</a>` : ""}
        </li>
      `)
      .join("")

    list.addEventListener("click", (e) => {
      const li = e.target.closest("li")
      if (!li) return
      const id = li.dataset.id

      if (e.target.tagName === "INPUT") {
        tasks.actions.toggle(id)
      } else {
        tasks.actions.open(id)
      }
    })

    container.querySelector("#newTaskBtn").onclick = () => {
      const id = tasks.actions.create({ title: "New Task" })
      tasks.actions.open(id)
    }
  },

  renderSide(container) {
    const id = tasks.state.selected
    if (!id) {
      container.innerHTML = "<p>No task selected.</p>"
      return
    }

    const item = scrappy.db.tasks.find(t => t.id === id)

    container.innerHTML = `
      <h2>${item.title}</h2>
      <p>Status: ${item.done ? "Done" : "Not Done"}</p>
      ${item.noteLink ? `<p>Linked Note: <a href="${item.noteLink}">${item.noteLink}</a></p>` : ""}
    `
  }
}

scrappy.register(tasks)
```

